#!/bin/sh
bookmarks_file="/home/rickard/Documents/bookmarks/bookmarks.txt"

choice="$(awk 'BEGIN{print "+ Add bookmark"}{ $1=""; print $0}' "$bookmarks_file" | dmenu -l 15 -i -p "Open bookmark:")"

[ -z "$choice" ] && exit 1


if [ "$choice" = "+ Add bookmark" ]; then
  url=$(dmenu -p "Url:" <&-)
  [ -z "$url" ] && exit 1
  name=$(dmenu -p "Name:" <&-)
  [ -z "$name" ] && exit 1
  echo "$url $name" >> "$bookmarks_file"
else
  grep -F "$choice" "$bookmarks_file" | awk '{print $1}' | xargs zen-browser
fi
